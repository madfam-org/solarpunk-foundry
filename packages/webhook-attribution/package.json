{
  "name": "@madfam/webhook-attribution",
  "version": "0.1.0",
  "description": "Shared HMAC signing/verification + idempotency for the MADFAM signed payment-attribution fan-out (x-madfam-signature)",
  "author": "MADFAM <tech@madfam.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/madfam-org/solarpunk-foundry.git",
    "directory": "packages/webhook-attribution"
  },
  "homepage": "https://madfam.io",
  "bugs": {
    "url": "https://github.com/madfam-org/solarpunk-foundry/issues"
  },
  "keywords": [
    "madfam",
    "solarpunk",
    "webhook",
    "hmac",
    "signature",
    "payment",
    "attribution",
    "idempotency"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.madfam.io/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
