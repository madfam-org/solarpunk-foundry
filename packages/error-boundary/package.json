{
  "name": "@madfam/error-boundary",
  "version": "0.1.0",
  "description": "Shared error boundary components for the MADFAM/Solarpunk ecosystem",
  "author": "MADFAM <tech@madfam.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/madfam-org/solarpunk-foundry.git",
    "directory": "packages/error-boundary"
  },
  "homepage": "https://madfam.io",
  "bugs": {
    "url": "https://github.com/madfam-org/solarpunk-foundry/issues"
  },
  "keywords": [
    "madfam",
    "solarpunk",
    "error-boundary",
    "react",
    "error-handling",
    "sentry"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "@madfam/sentry": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@madfam/sentry": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "react": "^18.3.1",
    "tsup": "^8.0.2",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
